}

int hash_fun_2(elem_t elem) {
    int hash = elem.string[0];
    return hash;
}

int hash_fun_3(elem_t elem) {
    int hash = elem.len;
    return hash;
}

int hash_fun_4(elem_t elem) {
    int hash = 0;
    for (uint32_t i = 0; i < elem.len; i++) {
        hash += elem.string[i];
    }

    return hash;            
}   

int hash_fun_5(elem_t elem) {
    int hash = 0;
    for (uint32_t i = 0; i < elem.len; i++) {
        hash = (hash << 1) ^ elem.string[i];
    }

    return hash;
}

