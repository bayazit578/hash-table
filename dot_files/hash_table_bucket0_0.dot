digraph {
 rankdir=LR;
splines=ortho;
nodesep=0.9;
ranksep=0.75;
node [fontname="Fira Mono",color="#FF0000",style="filled",shape=tripleoctagon,fillcolor="#FFB0B0",];
node_0[shape=record,label="ind: 0 | data: NULL | { prev: 1 | next: 1 } ",color="#0000FF",style="filled,bold,rounded",fillcolor="#B0B0FF"];
node_1[shape=record,label=" ind: 1 | data: gay | { prev: 0 | next: 0 } ",style="filled,rounded",color="#03c03c",fillcolor="#B0FFB0",constraint=false];
node_0 -> node_1 [weight=1000, style=solid];
node_1 -> node_0 [weight=1000, style=solid];
node_free [label=free,color="#03c03c",shape=record,style="filled,rounded",fillcolor="#B0FFB0"];
}
